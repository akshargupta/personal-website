---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Akshar Gupta — Technical Learning Experience Designer' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-home">akshar gupta</a>
        <div class="nav-links">
          <a href="/projects">projects</a>
          <a href="/blog">blog</a>
          <a href="/cv">cv</a>
          <ThemeToggle />
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p class="muted">
        &copy; {new Date().getFullYear()} Akshar Gupta &middot;
        <a href="https://github.com/akshargupta/personal-website">source</a>
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    margin-bottom: 2rem;
  }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  nav a {
    text-decoration: none;
  }
  .nav-home {
    font-weight: 600;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
</style>
