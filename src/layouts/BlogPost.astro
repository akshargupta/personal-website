---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
}

const { title, date, description } = Astro.props;
const formattedDate = date.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<Base title={`${title} — Akshar Gupta`} description={description}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <time class="muted" datetime={date.toISOString()}>{formattedDate}</time>
    </header>
    <slot />
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 2rem;
  }
  .post-header h1 {
    margin-bottom: 0.25rem;
  }
</style>
