---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  frontmatter: { title: string };
}

const { frontmatter } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Akshar Gupta — CV" />
    <title>{frontmatter.title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <nav>
        <a href="/">akshar gupta</a>
        <ThemeToggle />
      </nav>
    </header>
    <main>
      <div class="cv-header">
        <h1>CV</h1>
        <a href="/akshar-gupta-cv.pdf" download class="download-link">download pdf</a>
      </div>
      <article class="cv-content">
        <slot />
      </article>
    </main>
    <footer>
      <p class="muted">&copy; {new Date().getFullYear()} Akshar Gupta</p>
    </footer>
  </body>
</html>

<style>
  header { margin-bottom: 2rem; }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  nav a { font-weight: 600; text-decoration: none; }
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .download-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .cv-content :global(h2) {
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.25rem;
  }
  .cv-content :global(h3) {
    font-size: 1rem;
    margin-top: 1.25rem;
  }
  .cv-content :global(em) {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
</style>
